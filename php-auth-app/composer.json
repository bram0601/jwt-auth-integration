{
    "name": "auth/php-auth-app",
    "description": "Pure PHP JWT Authentication Application",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^7.0",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
